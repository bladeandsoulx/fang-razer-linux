{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fang",
  "version": "0.8.1",
  "identifier": "dev.fang.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fang",
        "width": 1100,
        "height": 740,
        "minWidth": 880,
        "minHeight": 620,
        "backgroundColor": "#0a0c0d"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb"
    ],
    "category": "Utility",
    "shortDescription": "Fan control and performance modes for Razer Blade laptops",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "fangd (>= 0.8.1)",
          "fangd (<< 0.9.0)"
        ]
      }
    }
  }
}
